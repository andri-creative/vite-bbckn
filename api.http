# ─────────────────────────────────────────────────────────
# USER / AUTH API
# ─────────────────────────────────────────────────────────

### 1. Setup Initial Admin (Hanya bisa digunakan saat database kosong)
POST {{url}}/v1/api/user/setup
Content-Type: application/json
x-timestamp: {{$timestamp}}

{
    "name": "Andrianto",
    "email": "andri@andri.creative.com",
    "username": "andri",
    "password": "password123"
}

### 2. Login User (Mendapatkan session cookie)
POST {{server}}/v1/api/user/login
Content-Type: application/json
x-timestamp: {{$timestamp}}

{
    "emailOrUsername": "andri",
    "password": "password123"
}

### 3. Check Auth Status
GET {{url}}/v1/api/user/check-auth
x-timestamp: {{$timestamp}}

### 4. Get All Users (Butuh Cookie Admin)
GET {{url}}/v1/api/user
x-timestamp: {{$timestamp}}

### 5. Create User Baru (Butuh Cookie Admin)
POST {{url}}/v1/api/user
Content-Type: application/json
x-timestamp: {{$timestamp}}

{
    "name": "User Biasa",
    "email": "user@example.com",
    "username": "user1",
    "password": "password123",
    "role": "User"
}

### 6. Delete User (Butuh Cookie Admin)
DELETE {{url}}/v1/api/user/REPLACE_WITH_USER_ID
x-timestamp: {{$timestamp}}

### 7. Logout User
POST {{url}}/v1/api/user/logout
x-timestamp: {{$timestamp}}

